{
  "name": "voice-input-desktop",
  "version": "2.0.0",
  "description": "智能语音输入法 — 桌面版",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npx tsc && npx electron .",
    "build:ts": "npx tsc",
    "build:electron": "npx electron-builder",
    "build:all": "npm run build:ts && npm run build:electron",
    "start": "npx electron ."
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.voiceinput.desktop",
    "productName": "智能语音输入法",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智能语音输入法"
    }
  }
}
